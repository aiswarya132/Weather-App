 the scenes.",uploadParserlistTxt:"<li class='list-number-item'><span class='text-bold'>Review each section</span> and make updates as needed.</li><li class='list-number-item'><span class='text-bold'>Use expert recommended examples</span> to optimize your resume.</li><li class='list-number-item'><span class='text-bold'>Download</span>, print, and apply!</li>",uploadSurveyBtnHeading:"What brought you here today?",uploadSurveyBtnSubHeading:"Select all that apply.",reviewCarouselBoosterTitle:"Check out our advanced resume-building features!",reviewCarouselMerchandiseTitle:"We know you’re here for a resume, but don't miss our top features at the finish line!",reviewCarousel:[{heading:"Old & Gold",para:"Leonardo Da Vinci is credited as the first person to create a resume in 1482!"},{heading:"Unique Skills",para:"One of the most unique skills listed in a resume was “competitive duck herding”!"},{heading:"The Power of Action",para:"Action verbs like “achieved,” “managed,” or “led” can make your resume stand out."},{heading:"T-Shirt Size Resumes",para:"A graduate once wore a t-shirt with his resume printed on the back. Talk about wearable resumes!"},{heading:"World Record Resumes",para:"A resume once set the world record at nearly 7 square meters. Not easy to handle!"}],reviewCarouselBooster:[{heading:"Strengthen your experience",para:"We have expert recommended examples in the experience section. Explore the ones relevant to you.",thumImg:window.RDL.Paths.ResourcePath+"images/desktop/rwz/Strngthn_Expr.svg",altText:"Strength Experience"},{heading:"Boost your skills",para:"Make your abilities shine! We have a comprehensive list of relevant skills in that section to guide you.",thumImg:window.RDL.Paths.ResourcePath+"images/desktop/rwz/Boost_Skills.svg",altText:"Boost Skills"},{heading:"Review your summary",para:"The summary section makes you unique. We have professional summary examples you can use and edit.",thumImg:window.RDL.Paths.ResourcePath+"images/desktop/rwz/Review_Summary.svg",altText:"Review Summary"}],reviewCarouselMerchantise:[{heading:"<span class='text-orange'>Build a cover letter </span><span class='text-block'>Why?</span>",para:"It’s an opportunity to tell your story, and show <span class='text-bold'>you’re a perfect fit for the job.</span>",thumImg:window.RDL.Paths.ResourcePath+"images/desktop/rwz/cover-letter.svg",altText:"Cover Letter"},{heading:"<span class='text-orange'>Get your resume past the bots!</span><span class='text-block'>How?</span>",para:"With access to <span class='text-bold'>UNLIMITED templates, fonts, and layouts</span> optimized to get your resume past the <span class='text-bold'>ATS scanning</span> tool and into the hands of a hiring manager.",thumImg:window.RDL.Paths.ResourcePath+"images/desktop/rwz/perfect-parser-optimized.svg",altText:"Perfect Parser"},{heading:"<span class='text-orange'>Get an exclusive resume review!</span><span class='text-block'>How?</span>",para:"<ul class=''><li class=''><span class='text-bold'>Upload</span> your resume for a review.</li><li class=''><span class='text-bold'>Get feedback</span> on every resume section.</li><li class=''>Receive a <span class='text-bold'>completed review</span> in 2-3 business days.</li></ul>",thumImg:window.RDL.Paths.ResourcePath+"images/desktop/rwz/resume-review.svg",altText:"Resume Review"},{heading:"<span class='text-orange'>Turn your resume into an <br/> online profile.</span><span class='text-block'>How?</span>",para:"<ul class=''><li class=''>Set up a professional profile at <span class='text-bold'>Bold.Pro.</span></li><li class=''><span class='text-bold'>Add tracking</span> so you know when hiring <br/>managers are viewing your profile.</li><li class=''>Update info based on your<span class='text-bold'> desired job.</span></li></ul>",thumImg:window.RDL.Paths.ResourcePath+"images/desktop/rwz/social-card-optimized.svg",altText:"Social Cards"},{heading:"<span class='text-orange'>Launch your career with <br/> Interview Prep Tools.</span><span class='text-block'>What’s included?</span>",para:"<ul class=''><li class=''>3h courses that can set you apart from 90% of applicants.</li><li class=''>Clear actionable lessons by top interview coaches.</li><li class=''>1000+ interview sets for practice.</li></ul>",thumImg:window.RDL.Paths.ResourcePath+"images/desktop/rwz/big-interview.svg",altText:"Big Interview"}]},Mi={selectResumeAiTag:"Enhanced by AI",selResumeAlreadySub0:"We’ll transfer everything to your new template",selResumeAlreadySub1:"Join the 375,000 users who have uploaded an existing resume",selResumeAlreadySub2:"Users save 35% more time by uploading an existing resume",toolTipdisclaimer1:"Desktop user uploads recorded since August 2023.",toolTipdisclaimer2:"Based on a comparison between the time taken by users to create a resume vs. upload an existing resume since August 2023."},Fi={selResumeHeading:"How would you like to build your resume?",selResumeCreateNew:window.RDL.Localization.selResumeCreateNew||"Start with a <span>new</span> resume",selResumeCreateNewSub:window.RDL.Localization.selResumeCreateNewSub||"Get step-by-step support with expert content suggestions at your fingertips!",selResumeAlready:window.RDL.Localization.selResumeAlready||"Upload an <span>existing</span> resume",selResumeAlreadySub:window.RDL.Localization.selResumeAlreadySub||"Edit your resume using expertly generated content in a fresh, new design.",selResumeTooltipV1:"Saves 35% of time",selResumeTooltipV2:"Chosen by 375K users",selResumeTooltipV3:"Powered by AI",selResumeTooltip1:"Based on a comparison between the time taken by users to create a resume vs. upload an existing one since August 2023.",selResumeTooltip2:"Based on the no. of resumes uploaded via desktop since August 2023.",selResumefileAccepted:"<span>Acceptable file types: </span>DOC, DOCX, PDF, HTML, RTF, TXT",finalMoreOptions:"More upload options",selResumeChooseFile:"Choose file",createResumeHead:"Create new",btnDropBox:"Upload from Dropbox",btnGoogleDrive:"Up