ter-spacing: 0;\n              margin-bottom: 0px;\n              margin-top: 0px;\n          }\n          #howItWorks.key-feature-animation .key-features-container {\n            max-width: 1140px;\n            margin: 0 auto;\n            padding: 32px 0px 5px 0px;\n          }\n          #howItWorks.key-feature-animation .key-features-grid {\n              display: flex;\n              justify-content: center;\n              height: 323px;\n          }\n          #howItWorks.key-feature-animation .feature-icon {\n              width: 80px;\n              margin-bottom: 24px;\n              margin-top: 24px;\n          }\n          #howItWorks.key-feature-animation .feature-title {\n              font-size: 2.8rem;\n              line-height: 3.4rem;\n              font-weight: 800;\n              font-family: 'Work Sans';\n              margin-bottom: 12px;\n          }\n          #howItWorks.key-feature-animation .progress-line {\n            width: calc(100% - 48px);\n            height: 4px;\n            position: absolute;\n            top: 24px;\n            left: 24px;\n            background: rgba(204, 204, 204, 1);\n            border-radius: 80px;\n          }\n          #howItWorks.key-feature-animation .progress-line-fill {\n            height: 4px;\n            border-radius: 80px;\n            width: 0;\n            display: block;\n            visibility: hidden;\n            background: rgba(151, 236, 163, 1);\n          }\n          #howItWorks.key-feature-animation.animation-started .feature-card1 .step1-progress {\n            animation: fillBackground1 2s linear 0s forwards;\n          }\n          #howItWorks.key-feature-animation.animation-started .feature-card2 .step2-progress {\n            animation: fillBackground1 2s linear 2.2s forwards;\n          }\n          #howItWorks.key-feature-animation.animation-started .feature-card3 .step3-progress {\n            animation: fillBackground1 2s linear 4.4s forwards;\n          }\n          @keyframes fillBackground1 {\n            0% {\n              width: 0%;\n            }\n            100% {\n              width: 100%;\n              visibility: visible;\n            }\n          }\n          #howItWorks.key-feature-animation .feature-card {\n              position: relative;\n              margin: 0px 24px 0px 0px;\n              padding: 24px;\n              color: #000;\n              border: 1px solid rgba(204, 204, 204, 1);\n              border-radius: 8px;\n              box-shadow: 0px 8px 16px 0px rgba(91, 115, 139, 0.16), 0px 0px 2px 0px rgba(91, 115, 139, 0.16);\n              height: 202px;\n              overflow: hidden;\n              min-width: 364px;\n          }\n          #howItWorks.key-feature-animation.animation-started .feature-card1 {\n              animation: increaseHeight 0.2s linear 1s forwards;\n          }\n          #howItWorks.key-feature-animation.animation-started .feature-card2 {\n              animation: increaseHeight 0.2s linear 3.2s forwards;\n          }\n          #howItWorks.key-feature-animation.animation-started .feature-card3 {\n              animation: increaseHeight 0.2s linear 5.4s forwards;\n          }\n          @keyframes increaseHeight {\n            0% {\n              height: 222px;\n            }\n            100% {\n              height: 323px;\n            }\n          }\n          #howItWorks.key-feature-animation .feature-list {\n            padding: 0;\n            margin: 0;\n          }\n          #howItWorks.key-feature-animation .feature-list li {\n            font-size: 1.8rem;\n            line-height: 2.7rem;\n            font-family: Inter;\n            margin-bottom: 8px;\n            display: flex;\n            align-items: center;\n          }\n          #howItWorks.key-feature-animation .feature-card2 .feature-list li:last-child {\n            white-space: nowrap;\n          }\n          #howItWorks.key-feature-animation .tick-icon {\n            margin-right: 10px;\n            display: inline-flex;\n            align-items: center;\n            flex-shrink: 0;\n          }\n          #howItWorks.key-feature-animation .feature-card:last-child {\n            margin: 0px;  \n          }\n          @media (max-width: 1199px) {\n            #howItWorks.key-feature-animation .feature-card {\n              min-width: 304px;\n              padding: 14px;\n              height: 160px;\n            } \n            #howItWorks.key-feature-animation .feature-title {\n                font-size: 2.2rem;\n                line-height: 3rem;\n            }\n            #howItWorks.key-feature-animation .feature-list li {\n                font-size: 1.6rem;\n                line-height: 2.4rem;\n            }\n            #howItWorks.key-feature-animation .feature-icon img {\n                width: 60px;\n                height: 60px;\n            }\n            #howItWorks.key-feature-animation .progress-line {\n                top: 14px;\n            }\n            #howItWorks.key-feature-animation .feature-card2 .feature-list li:last-child {\n                white-space: normal;\n            }\n          }\n          @media (max-width: 991px) {\n            #howItWorks.key-feature-animation .feature-card {\n              min-width: 220px;\n              height: 160px;\n            } \n            #howItWorks.key-feature-animation .feature-title {\n                font-size: 2rem;\n                line-height: 2.4rem;\n            }\n            #howItWorks.key-feature-animation .feature-list li {\n                font-size: 1.3rem;\n                line-height: 2rem;\n            }\n          }\n          \n          "}})}),(0,i.jsx)("div",{className:"key-features-container",children:(0,i.jsx)("div",{className:"key-features-grid",children:n.map((e,t)=>(0,i.jsxs)("div",{className:"feature-card feature-card".concat(t+1),children:[(0,i.jsx)("div",{className:"progress-line",children:(0,i.jsx)("span",{className:"progress-line-fill step".concat(t+1,"-progress